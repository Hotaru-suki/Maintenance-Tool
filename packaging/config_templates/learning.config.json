{
  "newItemPolicy": {
    "minBytes": 1048576,
    "promoteNewPaths": true
  },
  "changePolicy": {
    "sizeDeltaBytes": 33554432,
    "sizeDeltaRatio": 0.5
  },
  "stalePolicy": {
    "missingCountThreshold": 3,
    "suggestOnly": true
  },
  "groupingPolicy": {
    "groupBy": [
      "category",
      "scope"
    ]
  },
  "safetyPolicy": {
    "refuseSymlinks": true,
    "requireManualConfirmForLearnedTargets": true,
    "requireManualConfirmAboveBytes": 536870912,
    "maxItemsPerRun": 50,
    "maxBytesPerRun": 2147483648,
    "allowedRoots": [
      {
        "path": "%LOCALAPPDATA%",
        "scopeHint": "windows",
        "enabled": true
      },
      {
        "path": "%APPDATA%\\Code",
        "scopeHint": "windows",
        "enabled": true
      }
    ]
  }
}
